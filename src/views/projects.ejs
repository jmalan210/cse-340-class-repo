
    <%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
       <h2>Upcoming Service Projects</h2>
<ul>
    <% service_projects.forEach(service_project => { %>
        <li class="card">
            <strong><%= new Date(service_project.project_date).toLocaleDateString('en-US', {
                month: 'long', 
                day: 'numeric', 
                year: 'numeric'
            }) %>:</strong>

            <span><%= service_project.title%> <span></span><em>(<%= service_project.organization_name %>)</em></span>
        
        </li>
        <%
    }); %>
</ul>
    </main>
    <%- include('partials/footer') %>
