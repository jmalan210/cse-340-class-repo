<%- include('partials/header') %>

<main>

   
    <h1><%= title %></h1>
       
    <h2><%= projectDetails.title %></h2>
    <p><strong>Description:</strong> <%= projectDetails.description %></p>
    <p><strong>Date:</strong> <%= new Date(projectDetails.project_date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></p>
    <p><strong>Location:</strong> <%= projectDetails.location %></p>
    <p><strong>Partner Organization:</strong> <a href="/organization/<%= projectDetails.organization_id %>"><%= projectDetails.name %></a> </p>
    <ul class="tag-list">
      <% categories.forEach(category => { %>
         <li class="tag"><a href="/category/<%= category.category_id %>"><%= category.name %></a></li>
     <% }) %>
    </ul>
    <a href="/edit-project/<%= projectDetails.project_id %>">Edit Project</a>
    <a href="/assign-categories/<%= projectDetails.project_id %>">Edit Categories</a>

       </main>
    <%- include('partials/footer') %>
