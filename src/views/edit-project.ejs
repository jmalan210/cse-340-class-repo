<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

 <form action="/edit-project/<%=projectDetails.project_id %>" method="POST">
    <div class="form-group">
      <label for="title">Project Title</label>
      <input
        type="text"
        id="title"
        name="title"
        value="<%= projectDetails.title %>"
        required
        maxlength="150"
      />
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea
        id="description"
        name="description"
        required
        maxlength="500"
      ><%= projectDetails.description %></textarea>
    </div>

    <div class="form-group">
      <label for="location">Location</label>
      <input
        type="text"
        id="location"
        name="location"
        value="<%= projectDetails.location %>"
        maxlength="255"
        required
      />
    </div>

    <div class="form-group">
        <label for="project_date">Project Date</label>
        <input type="date"
        id="project_date"
        name="project_date"
        maxlength="255"
        value="<%= projectDetails.project_date %>"
        />

    </div>

    <div class="form-group">
      <label for="organizationId">Organization</label>
      <select
       
        id="organizationId"
        name="organizationId"
        required
      >
      <option value="">Select partner organization</option>
      <% organizations.forEach(org => { %>
        <option value="<%= org.organization_id %>"><%= org.name %></option>
     <% }); %>
      </select>
    </div>

    <button type="submit">Update Project</button>
  </form>

</main>
<%- include('partials/footer') %>