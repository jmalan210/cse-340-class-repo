<%- include('partials/header') %>
<main>
    <h1><%= projectDetails? projectDetails.title : "Project not found" %></h1>

 <form action="/assign-categories/<%=projectId %>" method="POST">
    <div class="form-group">
      <% allCategories.forEach(category => { %>
        <div>
            <input 
            type="checkbox"
            id="category-<%= category.category_id %>"
            name="categoryIds"
            value="<%= category.category_id %>"
            <%= projectCategories.some(ac => ac.category_id === category.category_id) ? 'checked' : '' %>
            />
            <label for="category-<%= category.category_id %>"><%= category.name %></>
        </div>
        <% }); %>
    </div>
    
    <button type="submit">Update Categories</button>
  </form>

</main>
<%- include('partials/footer') %>