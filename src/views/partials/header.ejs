<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <nav>
        <ul>
            <li><a href="/" class="<%= (currentPath=== '/') ? 'active' : '' %>">Home</a></li>
            <li><a href="/organizations" class="<%= (currentPath=== '/organizations') ? 'active' : '' %>">Organizations</a></li>
            <li><a href="/projects" class="<%= (currentPath=== '/projects') ? 'active' : '' %>">Projects</a></li>
            <li><a href="/categories" class="<%= (currentPath=== '/categories') ? 'active' : '' %>">Categories</a></li>
        </ul>
    </nav>

    
    <% const messages = flash(); %>
    <% Object.keys(messages).forEach(type => { %>
        <% if (messages[type].length > 0) { %>
            
                <% messages[type].forEach(msg => { %>
                    <%= msg %>
                <% }); %>
            
        <% } %>
    <% }); %>